{
    "$schema": "https://raw.githubusercontent.com/earendil-works/pi/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",
    "name": "noctalia",
    "vars": {
        "bg": "{{colors.surface.default.hex}}",
        "bgAlt": "{{colors.surface_container.default.hex}}",
        "bgAlt2": "{{colors.surface_container_high.default.hex}}",
        "fg": "{{colors.on_surface.default.hex}}",
        "fgMuted": "{{colors.on_surface_variant.default.hex}}",
        "accent": "{{colors.primary.default.hex}}",
        "accentAlt": "{{colors.secondary.default.hex}}",
        "tert": "{{colors.tertiary.default.hex}}",
        "err": "{{colors.error.default.hex}}",
        "outline": "{{colors.outline.default.hex}}",
        "outlineVar": "{{colors.outline_variant.default.hex}}",
        "primaryCont": "{{colors.primary_container.default.hex}}",
        "errorCont": "{{colors.error_container.default.hex}}",
        "surfaceLow": "{{colors.surface_container_low.default.hex}}",
        "surfaceLowest": "{{colors.surface_container_lowest.default.hex}}",
        "primaryFixed": "{{colors.primary_fixed.default.hex}}",
        "secondaryFixedDim": "{{colors.secondary_fixed_dim.default.hex}}"
    },
    "colors": {
        "accent": "accent",
        "border": "outline",
        "borderAccent": "accent",
        "borderMuted": "outlineVar",
        "success": "tert",
        "error": "err",
        "warning": "accentAlt",
        "muted": "fgMuted",
        "dim": "outlineVar",
        "text": "",
        "thinkingText": "fgMuted",
        "selectedBg": "bgAlt2",
        "userMessageBg": "bgAlt",
        "userMessageText": "fg",
        "customMessageBg": "surfaceLow",
        "customMessageText": "fg",
        "customMessageLabel": "accent",
        "toolPendingBg": "surfaceLowest",
        "toolSuccessBg": "surfaceLow",
        "toolErrorBg": "errorCont",
        "toolTitle": "accent",
        "toolOutput": "",
        "mdHeading": "accent",
        "mdLink": "accentAlt",
        "mdLinkUrl": "fgMuted",
        "mdCode": "tert",
        "mdCodeBlock": "",
        "mdCodeBlockBorder": "outlineVar",
        "mdQuote": "fgMuted",
        "mdQuoteBorder": "outlineVar",
        "mdHr": "outlineVar",
        "mdListBullet": "tert",
        "toolDiffAdded": "tert",
        "toolDiffRemoved": "err",
        "toolDiffContext": "fgMuted",
        "syntaxComment": "fgMuted",
        "syntaxKeyword": "accentAlt",
        "syntaxFunction": "accent",
        "syntaxVariable": "fg",
        "syntaxString": "tert",
        "syntaxNumber": "primaryFixed",
        "syntaxType": "secondaryFixedDim",
        "syntaxOperator": "accent",
        "syntaxPunctuation": "fgMuted",
        "thinkingOff": "outlineVar",
        "thinkingMinimal": "outline",
        "thinkingLow": "accent",
        "thinkingMedium": "tert",
        "thinkingHigh": "accentAlt",
        "thinkingXhigh": "err",
        "bashMode": "tert"
    }
}
